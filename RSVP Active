<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RSVP - Maklumat Kehadiran</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', serif;
            background: linear-gradient(135deg, #ffeef8
 0%, #fff4e6
 100%);
            min-height: 100vh;
            padding: 20px;
        }

        /* MODAL CONTAINER */
        .modal-container {
            background: white;
            border-radius: 20px;
            max-width: 900px;
            margin: 20px auto;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            overflow: hidden;
            animation: slideUp 0.4s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* HEADER */
        .modal-header {
            background: linear-gradient(135deg, #f5f5f5
 0%, #ffffff
 100%);
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #eee;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .modal-title {
            font-size: 1.3em;
            color: #333;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .close-btn {
            background: transparent;
            border: none;
            font-size: 28px;
            color: #999;
            cursor: pointer;
            width: 35px;
            height: 35px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s ease;
        }

        .close-btn:hover {
            background: #f0f0f0
;
            color: #333;
            transform: rotate(90deg);
        }

        /* CONTENT */
        .modal-content {
            padding: 40px 30px;
            max-height: calc(100vh - 140px);
            overflow-y: auto;
        }

        .modal-content::-webkit-scrollbar {
            width: 8px;
        }

        .modal-content::-webkit-scrollbar-track {
            background: #f9f9f9
;
        }

        .modal-content::-webkit-scrollbar-thumb {
            background: #ffc0d3
;
            border-radius: 10px;
        }

        /* SECTION 1: FORM */
        .form-section {
            margin-bottom: 40px;
        }

        .section-title {
            text-align: center;
            color: #d4567a
;
            font-size: 2em;
            margin-bottom: 10px;
            font-weight: 300;
            letter-spacing: 2px;
        }

        .section-subtitle {
            text-align: center;
            color: #888;
            margin-bottom: 30px;
            font-size: 1.05em;
        }

        .form-container {
            width: 100%;
            height: 1000px;
            border: none;
            border-radius: 10px;
        }

        /* SECTION 2: WISH BOARD */
        .wish-section {
            padding-top: 40px;
            border-top: 2px solid #ffeef8
;
        }

        .wishes-container {
            display: grid;
            gap: 20px;
            max-height: 600px;
            overflow-y: auto;
            padding-right: 10px;
        }

        .wishes-container::-webkit-scrollbar {
            width: 8px;
        }

        .wishes-container::-webkit-scrollbar-track {
            background: #f9f9f9
;
            border-radius: 10px;
        }

        .wishes-container::-webkit-scrollbar-thumb {
            background: #ffc0d3
;
            border-radius: 10px;
        }

        .wish-card {
            background: linear-gradient(135deg, #fff5f7
 0%, #fffbf0
 100%);
            border-left: 4px solid #ffc0d3
;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            animation: slideIn 0.5s ease-out;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .wish-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .wish-icon {
            font-size: 2em;
            margin-bottom: 10px;
            display: block;
        }

        .wish-name {
            font-weight: bold;
            color: #d4567a
;
            font-size: 1.2em;
            margin-bottom: 8px;
        }

        .wish-message {
            color: #555;
            line-height: 1.6;
            font-size: 1.05em;
        }

        .loading {
            text-align: center;
            color: #d4567a
;
            font-size: 1.2em;
            padding: 40px;
        }

        .no-wishes {
            text-align: center;
            color: #999;
            padding: 40px;
            font-size: 1.1em;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .modal-container {
                margin: 10px;
            }

            .modal-header {
                padding: 15px 20px;
            }

            .modal-content {
                padding: 30px 20px;
            }

            .section-title {
                font-size: 1.6em;
            }

            .form-container {
                height: 800px;
            }
        }
    </style>
</head>
<body>

    <div class="modal-container">
        <!-- HEADER -->
        <div class="modal-header">
            <div class="modal-title">RSVP</div>
            <button class="close-btn" onclick="window.history.back()">&times;</button>
        </div>

        <!-- CONTENT -->
        <div class="modal-content">
            <!-- SECTION 1: RSVP FORM -->
            <div class="form-section">
                <h1 class="section-title">🌸 RSVP Kehadiran 🌸</h1>
                <p class="section-subtitle">Sila isi maklumat kehadiran dan tinggalkan ucapan & doa</p>
                
                <iframe 
                    class="form-container"
                    src="https://docs.google.com/forms/d/e/1FAIpQLScJ-TJqnnWVGXYiFAtu-K8NpT2YLw4b9n_u9Hio_ZCEiIyPfg/viewform?embedded=true"
                    frameborder="0"
                    marginheight="0"
                    marginwidth="0">
                    Loading…
                </iframe>
            </div>

            <!-- SECTION 2: LIVE WISH BOARD -->
            <div class="wish-section">
                <h2 class="section-title">💐 Ucapan & Doa 💐</h2>
                <p class="section-subtitle">Terima kasih atas ucapan dan doa yang ikhlas</p>

                <div id="wishesContainer" class="wishes-container">
                    <div class="loading">🌸 Memuatkan ucapan...</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwrbNyA2eSThXM7BPAwLyO9drhWtEO909E7Ie1K1IllfTkzV_esX17q1Zl9eapD7UO-Rg/exec';
        const REFRESH_INTERVAL = 10000;

        const gardenIcons = ['🌸', '🌺', '🌼', '🌻', '🌷', '🌹', '💐', '🏵️'];

        function getRandomIcon() {
            return gardenIcons[Math.floor(Math.random() * gardenIcons.length)];
        }

        function displayWishes(wishes) {
            const container = document.getElementById('wishesContainer');
            
            if (!wishes || wishes.length === 0) {
                container.innerHTML = '<div class="no-wishes">Belum ada ucapan. Jadilah yang pertama! 🌸</div>';
                return;
            }

            const sortedWishes = wishes.reverse();
            
            container.innerHTML = sortedWishes.map(wish => `
                <div class="wish-card">
                    <span class="wish-icon">${getRandomIcon()}</span>
                    <div class="wish-name">${wish.name}</div>
                    <div class="wish-message">${wish.message}</div>
                </div>
            `).join('');
        }

        function loadWishes() {
            const callbackName = 'jsonpCallback_' + Date.now();
            
            window[callbackName] = function(data) {
                displayWishes(data);
                delete window[callbackName];
            };

            const script = document.createElement('script');
            script.src = `${APPS_SCRIPT_URL}?callback=${callbackName}&_=${Date.now()}`;
            script.onerror = function() {
                document.getElementById('wishesContainer').innerHTML = 
                    '<div class="no-wishes">Tidak dapat memuatkan ucapan. Sila refresh page.</div>';
                delete window[callbackName];
            };
            
            document.body.appendChild(script);
            setTimeout(() => {
                if (document.body.contains(script)) {
                    document.body.removeChild(script);
                }
            }, 5000);
        }

        loadWishes();
        setInterval(loadWishes, REFRESH_INTERVAL);
    </script>

</body>
</html>
